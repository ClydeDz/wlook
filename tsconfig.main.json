{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "module": "commonjs",
    "target": "ES2022",
    "baseUrl": "src",
    "paths": {
      "@shared/*": ["shared/*"],
      "@core/*": ["core/*"]
    }
  },
  "include": ["src/agent/**/*", "src/core/**/*", "src/shared/**/*"]
}
